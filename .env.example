SUPABASE_PUBLISHABLE_KEY=sb_publishable_RrxRQXVCir9HMya4WpT9Rw_F0VQS4Ko

# Required for real backend writes/seeding. Keep this server-only.
SUPABASE_SERVICE_ROLE_KEY=

# Required in production. Use the same value for seed/import and runtime lookup.
SECURITY_CODE_PEPPER=replace-with-a-long-random-server-secret

# Required in production. 32 bytes encoded as hex or base64url.
MEMO_ENCRYPTION_KEY=

# Keep true while developing so local demo tickets still work before Supabase is seeded.
SUPABASE_DEMO_FALLBACK=true

# Keep false outside demos. When false, /api/demo-codes returns no public codes.
PUBLIC_DEMO_CODES_ENABLED=false

# Solana devnet verification settings.
SOLANA_RPC_ENDPOINT=https://api.devnet.solana.com
TREASURY_ADDRESS=CRQ3vWquPewjJhfvuJFVWiW1qkwoSD94W694SjkU6JuM

# Current implemented mode: public Solana transfer with encrypted memo.
PAYMENT_PRIVACY_MODE=direct_onchain_encrypted_memo

# Required for admin-only endpoints such as memo decryption.
ADMIN_TOKEN=

# Optional read-only/restricted operational tokens for admin panel reads.
REVIEWER_TOKEN=
FINANCE_TOKEN=

# Optional separate token for camera/model ingestion. Falls back to ADMIN_TOKEN.
CAMERA_INGEST_TOKEN=

# Optional real vehicle registry adapter. Without it, local seeded plates are used for dev.
REGISTRY_API_URL=
REGISTRY_API_TOKEN=
